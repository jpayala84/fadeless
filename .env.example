# Example environment variables (safe to commit).
# Copy to `.env.local` and fill in real values.

DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

SPOTIFY_CLIENT_ID="your-spotify-client-id"
SPOTIFY_CLIENT_SECRET="your-spotify-client-secret"
SPOTIFY_REDIRECT_URI="https://fadeless.app/api/auth/callback"
SPOTIFY_SCOPES="user-read-email user-library-read playlist-read-private playlist-read-collaborative user-follow-read user-top-read user-read-recently-played"

ENCRYPTION_SECRET="replace-with-32+char-secret"
SESSION_SECRET="replace-with-32+char-secret"

NEXT_PUBLIC_APP_URL="https://fadeless.app"

RESEND_API_KEY="your-resend-api-key"
EMAIL_FROM="alerts@fadeless.app"
